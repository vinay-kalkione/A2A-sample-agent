# Copy to .env and add your keys
GEMINI_API_KEY=sk-your-openai-api-key-here

# Hosted environment: set your public base URL (no trailing slash)
# BASE_URL=https://your-agent.example.com
# Optional: gRPC endpoint if exposed (default: localhost:4001 for local dev)
# GRPC_URL=your-agent.example.com:443
